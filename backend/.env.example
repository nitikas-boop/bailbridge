# ─────────────────────────────────────────────
# BailBridge — Environment Variables Template
# ─────────────────────────────────────────────

# Firebase Service Account (JSON string or path to .json file)
FIREBASE_SERVICE_ACCOUNT=

# Firebase Cloud Storage bucket name
FIREBASE_STORAGE_BUCKET=

# Google Gemini API key
GEMINI_API_KEY=

# Google Maps Platform API key
GOOGLE_MAPS_API_KEY=

# App settings
PORT=8000
ALLOWED_ORIGINS=*

# Firestore Collections (Internal Reference)
# - conversations: stores chat threads by case_id
# - notifications: stores in-app alerts by user_id
# - cases: stores core case metadata
